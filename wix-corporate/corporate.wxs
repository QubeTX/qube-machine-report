<!--
  TR-300 Corporate Edition (perUser MSI).

  This template ships alongside `wix/main.wxs` (the Global / perMachine MSI).
  Built by `.github/workflows/corporate-msi.yml` after `release.yml` finishes
  publishing the GitHub Release, then uploaded as
  `tr300-x86_64-pc-windows-msvc-corporate.msi`.

  Differences vs main.wxs (intentional — do not converge):
    - InstallScope="perUser" on the Package element. Sufficient on WiX 3.11+
        to install without UAC on machines where the user has no admin rights
        but still has write access to %LocalAppData%. Earlier drafts also set
        ALLUSERS="" + MSIINSTALLPERUSER=1 as Property elements, but WiX 3.11
        candle rejects ALLUSERS Value="" with CNDL0006 ("empty string"). Per
        WiX docs, InstallScope="perUser" is equivalent to ALLUSERS unset.
    - UpgradeCode is a DIFFERENT GUID from the Global edition.
        Same UpgradeCode across editions would confuse Windows Installer
        and break upgrades in both directions. Registered or exact-path Global
        state blocks before mutation; an explicit format choice within
        Corporate removes only its same-edition MSI/Inno counterpart.
    - Install location: %LocalAppData%\Programs\tr300\bin\tr300.exe
        instead of %ProgramFiles%\tr300\bin\tr300.exe.
    - PATH entry: user PATH (HKCU\Environment\Path) instead of
        system PATH (HKLM\...\Session Manager\Environment\Path).
    - Product Name: "tr300 (Corporate Edition)" — distinct ARP entry.

  If install paths/identity in this file change, update src/update.rs,
  inno/corporate.iss, validation workflow, and the ADR in lockstep.
-->

<!--
  The "cargo wix" subcommand provides a variety of predefined variables available
  for customization of this template. The values for each variable are set at
  installer creation time. The following variables are available:

  TargetTriple      = The rustc target triple name.
  TargetEnv         = The rustc target environment. This is typically either
                      "msvc" or "gnu" depending on the toolchain downloaded and
                      installed.
  TargetVendor      = The rustc target vendor. This is typically "pc", but Rust
                      does support other vendors, like "uwp".
  CargoTargetBinDir = The complete path to the directory containing the
                      binaries (exes) to include. The default would be
                      "target\release\". If an explicit rustc target triple is
                      used, i.e. cross-compiling, then the default path would
                      be "target\<CARGO_TARGET>\<CARGO_PROFILE>",
                      where "<CARGO_TARGET>" is replaced with the "CargoTarget"
                      variable value and "<CARGO_PROFILE>" is replaced with the
                      value from the "CargoProfile" variable. This can also
                      be overridden manually with the "target-bin-dir" flag.
  CargoTargetDir    = The path to the directory for the build artifacts, i.e.
                      "target".
  CargoProfile      = The cargo profile used to build the binaries
                      (usually "debug" or "release").
  Version           = The version for the installer. The default is the
                      "Major.Minor.Fix" semantic versioning number of the Rust
                      package.
-->

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='tr300 (Corporate Edition)'
        UpgradeCode='93F465CB-7F66-4930-A773-FDA017E8FD64'
        Manufacturer='Emmett S'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='Cross-platform system information report (Corporate Edition, per-user install)'
            Manufacturer='Emmett S'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perUser'
            SummaryCodepage='1252'
            />

        <!-- perUser scope: InstallScope='perUser' on the Package element above
             is sufficient on WiX 3.11+ to make this a per-user install with
             no UAC. We do NOT declare ALLUSERS or MSIINSTALLPERUSER Properties
             explicitly:
             - `<Property Id='ALLUSERS' Value=''/>` was rejected by WiX 3.11
               candle with CNDL0006 ("Property/@Value attribute's value cannot
               be an empty string") and CNDL1006 (Property would be ignored).
               This was the root cause of the v3.15.0 release.yml failure on
               build-local-artifacts(x86_64-pc-windows-msvc) at run 25901237669.
             - `<Property Id='MSIINSTALLPERUSER' Value='1'/>` is redundant when
               InstallScope='perUser' is set; cargo-wix's MSI compile path
               doesn't need it.
             The WiX 3 docs say InstallScope='perUser' is "equivalent to setting
             ALLUSERS='' or NOT setting ALLUSERS at all". Sufficient. -->

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            AllowDowngrades='yes'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='tr300 (Corporate Edition) Installation'/>
        <Property Id='CONFLICTING_INNO_UNINSTALL'>
            <RegistrySearch Id='FindConflictingCorporateInno'
                Root='HKCU'
                Key='Software\Microsoft\Windows\CurrentVersion\Uninstall\{76A253EB-3A17-4730-9C54-5BE755A9BC4C}_is1'
                Name='UninstallString'
                Type='raw'
                Win64='yes'/>
        </Property>
        <Property Id='OTHEREDITIONINNO'>
            <RegistrySearch Id='FindGlobalInnoForSafeStop'
                Root='HKLM'
                Key='Software\Microsoft\Windows\CurrentVersion\Uninstall\{AB14223F-2693-4EC2-824F-BF53CC32D061}_is1'
                Name='UninstallString'
                Type='raw'
                Win64='yes'/>
        </Property>
        <Property Id='OTHEREDITIONBINARY'>
            <DirectorySearch Id='FindGlobalBinaryRoot'
                Path='[ProgramFiles64Folder]tr300\bin'
                Depth='0'>
                <FileSearch Id='FindGlobalBinary' Name='tr300.exe'/>
            </DirectorySearch>
        </Property>
        <Upgrade Id='5CD540A8-AD16-4B0F-8CE4-51FF641DE181'>
            <UpgradeVersion Minimum='0.0.0'
                IncludeMinimum='yes'
                OnlyDetect='yes'
                Property='OTHEREDITIONMSI'/>
        </Upgrade>
        <Condition Message='Global Edition is registered or its exact native binary remains. Setup stopped before changing anything. Uninstall it first or use the managed installer: https://github.com/QubeTX/qube-machine-report/releases/latest'>
            <![CDATA[(Installed AND REMOVE~="ALL") OR (NOT OTHEREDITIONMSI AND NOT OTHEREDITIONINNO AND NOT OTHEREDITIONBINARY)]]>
        </Condition>

        <!-- MIC-1 strict cross-method convergence (v4.2.0+) - see wix/main.wxs.
             The LaunchCondition above stops before mutation when Global native
             registration or exact-path state remains. The strict actions below
             target only an exact managed/Cargo owner. Interactive and passive
             installs share this mandatory, fail-closed behavior; there is no
             opt-out or forged registration cleanup. -->

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='LocalAppDataFolder'>
                <Directory Id='ProgramsFolder' Name='Programs'>
                    <Directory Id='APPLICATIONFOLDER' Name='tr300'>
                        <!-- Install-source marker. tr300 update reads this from
                             HKCU and picks the matching installer to download for
                             in-place upgrades. Value must match the literal
                             `corporate-msi` arm in src/update.rs. -->
                        <Component Id='InstallSourceMarker' Guid='405304C3-7EBD-42C6-8F4D-A88610980F8C'>
                        <RegistryValue
                            Root='HKCU'
                            Key='Software\TR300'
                            Name='InstallSource'
                            Type='string'
                            Value='msi-corporate'
                            KeyPath='yes'/>
                        <RegistryValue
                            Root='HKCU'
                            Key='Software\TR300'
                            Name='InstallSourceCorporate'
                            Type='string'
                            Value='msi-corporate'/>
                        </Component>
                        <Directory Id='Bin' Name='bin'>
                            <Component Id='Path' Guid='13D45AEB-3A5D-471C-B185-63DB3B897C66' KeyPath='yes'>
                                <!-- User PATH (HKCU\Environment\Path), not system PATH. -->
                                <Environment
                                    Id='PATH'
                                    Name='PATH'
                                    Value='[Bin]'
                                    Permanent='no'
                                    Part='last'
                                    Action='set'
                                    System='no'/>
                            </Component>
                            <Component Id='binary0' Guid='*'>
                                <File
                                    Id='exe0'
                                    Name='tr300.exe'
                                    DiskId='1'
                                    Source='$(var.CargoTargetBinDir)\tr300.exe'
                                    KeyPath='yes'/>
                            </Component>
                        </Directory>
                    </Directory>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs the tr300 binary (Corporate Edition, per-user).'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>

            <ComponentRef Id='binary0'/>
            <ComponentRef Id='InstallSourceMarker'/>

            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Add the install location of [ProductName] to your user PATH so the binary is callable from any terminal.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <Binary Id='MigrationProbe' SourceFile='$(var.CargoTargetBinDir)\tr300.exe'/>
        <CustomAction Id='PreflightCargoOwnership'
            BinaryKey='MigrationProbe'
            ExeCommand='migrate-cleanup --quiet --strict --dry-run --cargo-copy'
            Execute='immediate'
            Impersonate='yes'
            Return='check'/>

        <!-- MIC-1 strict convergence custom actions - see wix/main.wxs.
             Deferred and impersonated; FileKey='exe0' avoids WixUtilExtension
             (the Corporate MSI links only WixUIExtension). Return='check' makes
             incomplete ownership convergence fail the package transaction, and
             `NOT Installed` limits it to install/upgrade rather than uninstall or
             repair. -->
        <CustomAction Id='CleanCargoCopy'
            FileKey='exe0'
            ExeCommand='migrate-cleanup --quiet --strict --cargo-copy'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>
        <CustomAction Id='RemoveConflictingInno'
            Directory='TARGETDIR'
            ExeCommand='[CONFLICTING_INNO_UNINSTALL] /VERYSILENT /SUPPRESSMSGBOXES /NORESTART'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>
        <InstallExecuteSequence>
            <Custom Action='PreflightCargoOwnership' Before='RemoveConflictingInno'>
                <![CDATA[NOT Installed]]>
            </Custom>
            <Custom Action='RemoveConflictingInno' Before='InstallFiles'>
                <![CDATA[CONFLICTING_INNO_UNINSTALL AND NOT REMOVE~="ALL"]]>
            </Custom>
            <Custom Action='CleanCargoCopy' Before='InstallFinalize'>
                <![CDATA[NOT Installed]]>
            </Custom>
        </InstallExecuteSequence>

        <Property Id='ARPHELPLINK' Value='https://github.com/QubeTX/qube-machine-report'/>

        <UI>
            <UIRef Id='WixUI_FeatureTree'/>

        </UI>

    </Product>

</Wix>
